{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-site",
  "compatibility_date": "2026-05-05",
  "assets": {
    "directory": "out",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "liangkx.com", "custom_domain": true },
    { "pattern": "www.liangkx.com", "custom_domain": true }
  ]
}
